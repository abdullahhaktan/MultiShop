@*
    Ui Cart Summary Component
*@

<div class="tab-pane fade" id="tab-pane-3">
    <div class="row">
        <div class="col-md-6">
            <h4 class="mb-4">"Ürün Adı" için 1 değerlendirme</h4>
            <div class="media mb-4">
                <img src="img/user.jpg" alt="Görsel" class="img-fluid mr-3 mt-1" style="width: 45px;">
                <div class="media-body">
                    <h6>John Doe<small> - <i>01 Oca 2045</i></small></h6>
                    <div class="text-primary mb-2">
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star"></i>
                        <i class="fas fa-star-half-alt"></i>
                        <i class="far fa-star"></i>
                    </div>
                    <p>
                        Ürün oldukça kaliteli ve kullanımı rahat. Günlük kullanımda beklentileri karşılayan bir performans sunuyor.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <h4 class="mb-4">Yorum bırakın</h4>
            <small>E-posta adresiniz yayınlanmayacaktır. Zorunlu alanlar * ile işaretlenmiştir.</small>

            <div class="d-flex my-3">
                <p class="mb-0 mr-2">Puanınız * :</p>
                <div class="text-primary">
                    <i class="far fa-star"></i>
                    <i class="far fa-star"></i>
                    <i class="far fa-star"></i>
                    <i class="far fa-star"></i>
                    <i class="far fa-star"></i>
                </div>
            </div>

            <form>
                <div class="form-group">
                    <label for="message">Yorumunuz *</label>
                    <textarea id="message" cols="30" rows="5" class="form-control"></textarea>
                </div>

                <div class="form-group">
                    <label for="name">Adınız *</label>
                    <input type="text" class="form-control" id="name">
                </div>

                <div class="form-group">
                    <label for="email">E-posta *</label>
                    <input type="email" class="form-control" id="email">
                </div>

                <div class="form-group mb-0">
                    <input type="submit" value="Değerlendirme Gönder" class="btn btn-primary px-3">
                </div>
            </form>
        </div>
    </div>
</div>