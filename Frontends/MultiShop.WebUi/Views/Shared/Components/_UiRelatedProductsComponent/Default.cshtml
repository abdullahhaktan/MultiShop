<style>
    .related-slider-wrapper {
        position: relative;
        overflow: hidden;
    }

    .related-slider {
        display: flex;
        transition: transform 0.4s ease;
    }

        .related-slider .product-item {
            min-width: 25%;
            box-sizing: border-box;
            margin-right: 1px;
        }

    .related-btn {
        position: absolute;
        top: 40%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.3);
        color: white;
        border: none;
        padding: 10px 16px;
        cursor: pointer;
        z-index: 10;
        font-size: 18px;
        border-radius: 3px;
    }

        .related-btn:hover {
            background: rgba(0,0,0,0.6);
        }

    .related-btn-prev {
        left: 5px;
    }

    .related-btn-next {
        right: 5px;
    }

    @@media (max-width: 992px) {
        .related-slider .product-item {
            min-width: 33.33%;
        }
    }

    @@media (max-width: 768px) {
        .related-slider .product-item {
            min-width: 50%;
        }
    }

    @@media (max-width: 480px) {
        .related-slider .product-item {
            min-width: 100%;
        }
    }
</style>

<script>
    (function () {
        var relatedIndex = 0;

        function getRelatedVisible() {
            if (window.innerWidth <= 480) return 1;
            if (window.innerWidth <= 768) return 2;
            if (window.innerWidth <= 992) return 3;
            return 4;
        }

        window.relatedSlide = function (direction) {
            var slider = document.getElementById('relatedSlider');
            var slides = slider.querySelectorAll('.product-item');
            var visibleCount = getRelatedVisible();
            var maxIndex = slides.length - visibleCount;

            relatedIndex += direction;
            if (relatedIndex < 0) relatedIndex = 0;
            if (relatedIndex > maxIndex) relatedIndex = maxIndex;

            var slideWidth = slides[0].offsetWidth;
            slider.style.transform = 'translateX(-' + (relatedIndex * slideWidth) + 'px)';
        };

        window.addEventListener('resize', function () {
            relatedIndex = 0;
            var slider = document.getElementById('relatedSlider');
            if (slider) slider.style.transform = 'translateX(0)';
        });
    })();
</script>