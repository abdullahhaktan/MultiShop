<style>
    .main-sidebar {
        height: 100vh;
        overflow-y: auto;
        overflow-x: hidden;
        position: fixed;
        top: 0;
        left: 0;
        scroll-behavior: smooth;
    }

        .main-sidebar::-webkit-scrollbar {
            width: 6px;
        }

        .main-sidebar::-webkit-scrollbar-track {
            background: #2c3b41;
        }

        .main-sidebar::-webkit-scrollbar-thumb {
            background: #1e282c;
            border-radius: 3px;
        }

            .main-sidebar::-webkit-scrollbar-thumb:hover {
                background: #151b1f;
            }

    .main-sidebar {
        scrollbar-width: thin;
        scrollbar-color: #1e282c #2c3b41;
    }
</style>

