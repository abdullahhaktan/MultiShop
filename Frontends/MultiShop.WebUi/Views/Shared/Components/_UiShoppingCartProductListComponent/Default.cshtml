@model List<BasketItemDto>
@*
    Ui Shopping Cart Product List Component
*@

<div class="col-lg-8 table-responsive mb-5">
    <table class="table table-light table-borderless table-hover text-center mb-0">
        <thead class="thead-dark">
            <tr>
                <th class="text-left" style="padding-left: 15px;">Ürün</th>
                <th>Fiyat</th>
                <th>Miktar</th>
                <th>Toplam</th>
                <th>Kaldır</th>
            </tr>
        </thead>
        <tbody class="align-middle">

            @foreach (var item in Model)
            {
                <tr>
                    <td class="align-middle text-left d-flex align-items-center">
                        <img src="@item.ProductImageUrl" alt="@item.ProductName" class="img-fluid" style="width: 50px; height: 50px; object-fit: cover; margin-right: 15px; border-radius: 4px;">
                        <span>@item.ProductName</span>
                    </td>
                    <td class="align-middle">@item.Price</td>
                    <td class="align-middle">
                        <div class="input-group quantity mx-auto" style="width: 100px;">
                            <div class="input-group-btn">
                                <button class="btn btn-sm btn-primary btn-minus">
                                    <i class="fa fa-minus"></i>
                                </button>
                            </div>
                            <input type="text" class="form-control form-control-sm bg-secondary border-0 text-center" value="@item.Quantity">
                            <div class="input-group-btn">
                                <button class="btn btn-sm btn-primary btn-plus">
                                    <i class="fa fa-plus"></i>
                                </button>
                            </div>
                        </div>
                    </td>
                    <td class="align-middle">@item.Price</td>
                    <td class="align-middle">
                        <a href="/ShoppingCart/RemoveBasketItem/@item.ProductId" class="btn btn-sm btn-danger">
                            <i class="fa fa-times"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>