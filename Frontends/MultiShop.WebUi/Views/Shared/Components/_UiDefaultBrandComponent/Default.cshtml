@model List<ResultBrandDto>
@*
    Ui Layout Mark Component
*@

<div class="container-fluid py-5">
    <div class="row px-xl-5">
        <div class="col">
            <div class="vendor-slider-wrapper">
                <div class="vendor-slider" id="vendorSlider">
                    @foreach(var item in Model)
                    {
                        <div class="vendor-slide bg-light p-4">
                            <img src="@item.ImageUrl" alt="@item.ImageUrl">
                        </div>
                    }
                </div>
                <button class="vendor-btn vendor-btn-prev" onclick="vendorSlide(-1)">&#10094;</button>
                <button class="vendor-btn vendor-btn-next" onclick="vendorSlide(1)">&#10095;</button>
            </div>
        </div>
    </div>
</div>

<style>
    .vendor-slider-wrapper {
        position: relative;
        overflow: hidden;
    }

    .vendor-slider {
        display: flex;
        transition: transform 0.4s ease;
    }

    .vendor-slide {
        min-width: 20%;
        box-sizing: border-box;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .vendor-slide img {
            max-width: 100%;
            max-height: 80px;
            object-fit: contain;
        }

    .vendor-btn {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        background: rgba(0,0,0,0.3);
        color: white;
        border: none;
        padding: 8px 14px;
        cursor: pointer;
        z-index: 10;
        font-size: 18px;
        border-radius: 3px;
    }

        .vendor-btn:hover {
            background: rgba(0,0,0,0.6);
        }

    .vendor-btn-prev {
        left: 5px;
    }

    .vendor-btn-next {
        right: 5px;
    }

    @@media (max-width: 768px) {
        .vendor-slide {
            min-width: 50%;
        }
    }

    @@media (max-width: 480px) {
        .vendor-slide {
            min-width: 100%;
        }
    }
</style>

<script>
    (function () {
        var currentIndex = 0;
        var visibleCount = 5;

        function getVisibleCount() {
            if (window.innerWidth <= 480) return 1;
            if (window.innerWidth <= 768) return 2;
            return 5;
        }

        window.vendorSlide = function (direction) {
            var slider = document.getElementById('vendorSlider');
            var slides = slider.querySelectorAll('.vendor-slide');
            visibleCount = getVisibleCount();
            var maxIndex = slides.length - visibleCount;

            currentIndex += direction;
            if (currentIndex < 0) currentIndex = 0;
            if (currentIndex > maxIndex) currentIndex = maxIndex;

            var slideWidth = slides[0].offsetWidth;
            slider.style.transform = 'translateX(-' + (currentIndex * slideWidth) + 'px)';
        };

        window.addEventListener('resize', function () {
            currentIndex = 0;
            var slider = document.getElementById('vendorSlider');
            slider.style.transform = 'translateX(0)';
        });
    })();
</script>