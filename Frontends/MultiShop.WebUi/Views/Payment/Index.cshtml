@{
    ViewData["Title"] = "Ödeme Ekranı";
    Layout = "~/Views/UiLayout/Index.cshtml";
}

<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Courier+Prime&display=swap">

<style>
    .payment-wrapper {
        max-width: 460px;
        margin: 40px auto;
        padding: 30px;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    }

    /* ---------- KART ALANI (3D flip yapısı) ---------- */
    .card-scene {
        width: 100%;
        max-width: 400px;
        height: 220px;
        margin: 0 auto 30px;
        perspective: 1200px;
    }

    .credit-card {
        position: relative;
        width: 100%;
        height: 100%;
        transition: transform 0.6s cubic-bezier(0.4, 0.2, 0.2, 1);
        transform-style: preserve-3d;
    }

    .credit-card.flipped {
        transform: rotateY(180deg);
    }

    .card-face {
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 18px;
        backface-visibility: hidden;
        box-shadow: 0 15px 35px rgba(168, 46, 180, 0.35);
        overflow: hidden;
        color: #fff;
    }

    .card-front {
        background: linear-gradient(135deg, #8b2fd4 0%, #d92b8c 55%, #ff3d8f 100%);
        padding: 24px 26px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .card-back {
        background: linear-gradient(135deg, #8b2fd4 0%, #d92b8c 55%, #ff3d8f 100%);
        transform: rotateY(180deg);
        display: flex;
        flex-direction: column;
    }

    .card-top-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .chip {
        width: 42px;
        height: 32px;
        border-radius: 6px;
        background: linear-gradient(135deg, #e8d9a0, #c9b877);
        position: relative;
        overflow: hidden;
    }
    .chip::before, .chip::after {
        content: "";
        position: absolute;
        background: rgba(0,0,0,0.15);
    }
    .chip::before { width: 100%; height: 1px; top: 50%; }
    .chip::after { height: 100%; width: 1px; left: 50%; }

    .visa-logo {
        font-family: Arial, sans-serif;
        font-weight: 800;
        font-style: italic;
        font-size: 24px;
        letter-spacing: 1px;
    }

    .card-number-display {
        font-family: 'Courier Prime', monospace;
        font-size: 22px;
        letter-spacing: 3px;
        margin: 18px 0 10px;
        min-height: 28px;
        text-shadow: 0 2px 6px rgba(0,0,0,0.15);
    }

    .card-bottom-row {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
    }

    .card-label {
        font-size: 9px;
        opacity: 0.75;
        letter-spacing: 0.5px;
        margin-bottom: 4px;
        text-transform: uppercase;
    }

    .card-value {
        font-size: 14px;
        font-weight: 600;
        letter-spacing: 0.5px;
        min-height: 18px;
    }

    .card-back .magnetic-strip {
        height: 42px;
        background: #1c1c1c;
        margin-top: 22px;
    }

    .card-back .cvv-strip {
        margin: 20px 26px 0;
        display: flex;
        align-items: center;
        justify-content: flex-end;
    }

    .cvv-box {
        background: #fff;
        color: #333;
        font-family: 'Courier Prime', monospace;
        font-size: 14px;
        padding: 8px 14px;
        border-radius: 4px;
        min-width: 60px;
        text-align: center;
        letter-spacing: 3px;
    }

    .card-back .visa-logo {
        align-self: flex-end;
        margin: 14px 26px 0 0;
    }

    /* ---------- FORM ALANI ---------- */
    .form-group-custom { margin-bottom: 18px; }

    .form-group-custom label {
        display: block;
        font-size: 11px;
        font-weight: 700;
        color: #6b6b6b;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
    }

    .form-group-custom input,
    .form-group-custom select {
        width: 100%;
        padding: 12px 14px;
        border: 1.5px solid #e5e5e5;
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        transition: border-color 0.2s ease;
        background: #fff;
    }

    .form-group-custom input:focus,
    .form-group-custom select:focus {
        border-color: #d92b8c;
    }

    .row-triple {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
    }

    .pay-button {
        width: 100%;
        padding: 15px;
        border: none;
        border-radius: 12px;
        background: linear-gradient(90deg, #8b2fd4, #ff3d8f);
        color: #fff;
        font-weight: 700;
        font-size: 15px;
        letter-spacing: 0.5px;
        cursor: pointer;
        transition: opacity 0.2s ease, transform 0.15s ease;
    }
    .pay-button:hover { opacity: 0.92; }
    .pay-button:active { transform: scale(0.98); }
</style>

<div class="payment-wrapper">

    <!-- KART GÖRSELİ -->
    <div class="card-scene">
        <div class="credit-card" id="creditCard">
            <div class="card-face card-front">
                <div class="card-top-row">
                    <div class="chip"></div>
                    <div class="visa-logo">VISA</div>
                </div>
                <div class="card-number-display" id="displayNumber">1234 5678 9012 3456</div>
                <div class="card-bottom-row">
                    <div>
                        <div class="card-label">Kart Sahibi</div>
                        <div class="card-value" id="displayName">AD SOYAD</div>
                    </div>
                    <div>
                        <div class="card-label">Son Geçerlilik Tarihi</div>
                        <div class="card-value" id="displayExpiry">01 / 2025</div>
                    </div>
                </div>
            </div>
            <div class="card-face card-back">
                <div class="magnetic-strip"></div>
                <div class="cvv-strip">
                    <div class="cvv-box" id="displayCvv">***</div>
                </div>
                <div class="visa-logo">VISA</div>
            </div>
        </div>
    </div>

    <!-- FORM -->
    <form id="paymentForm">
        <div class="form-group-custom">
            <label>KART NUMARASI</label>
            <input type="text" id="cardNumber" maxlength="19" placeholder="1234 5678 9012 3456" autocomplete="off" />
        </div>

        <div class="form-group-custom">
            <label>KART SAHİBİ</label>
            <input type="text" id="cardName" placeholder="AD SOYAD" autocomplete="off" />
        </div>

        <div class="row-triple">
            <div class="form-group-custom">
                <label>AY BİLGİSİ</label>
                <select id="expiryMonth">
                    @for (int i = 1; i <= 12; i++)
                    {
                        <option value="@i.ToString("D2")">@i.ToString("D2")</option>
                    }
                </select>
            </div>
            <div class="form-group-custom">
                <label>YIL BİLGİSİ</label>
                <select id="expiryYear">
                    @{
                        int currentYear = DateTime.Now.Year;
                    }
                    @for (int y = currentYear; y <= currentYear + 10; y++)
                    {
                        <option value="@y">@y</option>
                    }
                </select>
            </div>
            <div class="form-group-custom">
                <label>CVV</label>
                <input type="text" id="cvv" maxlength="3" placeholder="123" autocomplete="off" />
            </div>
        </div>

        <button type="submit" class="pay-button">ÖDEMEYİ TAMAMLA</button>
    </form>
</div>

<script>
    (function () {
        const cardNumberInput = document.getElementById('cardNumber');
        const cardNameInput = document.getElementById('cardName');
        const expiryMonth = document.getElementById('expiryMonth');
        const expiryYear = document.getElementById('expiryYear');
        const cvvInput = document.getElementById('cvv');

        const displayNumber = document.getElementById('displayNumber');
        const displayName = document.getElementById('displayName');
        const displayExpiry = document.getElementById('displayExpiry');
        const displayCvv = document.getElementById('displayCvv');
        const creditCard = document.getElementById('creditCard');

        // Kart numarasını 4'lü gruplar halinde formatla
        cardNumberInput.addEventListener('input', function (e) {
            let value = e.target.value.replace(/\D/g, '').slice(0, 16);
            let formatted = value.replace(/(.{4})/g, '$1 ').trim();
            e.target.value = formatted;
            displayNumber.textContent = formatted.length > 0 ? formatted : '1234 5678 9012 3456';
        });

        // Kart sahibi adını büyük harfe çevirerek göster
        cardNameInput.addEventListener('input', function (e) {
            let value = e.target.value.toUpperCase();
            e.target.value = value;
            displayName.textContent = value.length > 0 ? value : 'AD SOYAD';
        });

        // Ay / yıl değişiminde son geçerlilik tarihini güncelle
        function updateExpiry() {
            displayExpiry.textContent = expiryMonth.value + ' / ' + expiryYear.value;
        }
        expiryMonth.addEventListener('change', updateExpiry);
        expiryYear.addEventListener('change', updateExpiry);

        // CVV odaklanınca kartı çevir, ayrılınca geri çevir
        cvvInput.addEventListener('focus', function () {
            creditCard.classList.add('flipped');
        });
        cvvInput.addEventListener('blur', function () {
            creditCard.classList.remove('flipped');
        });
        cvvInput.addEventListener('input', function (e) {
            let value = e.target.value.replace(/\D/g, '').slice(0, 3);
            e.target.value = value;
            displayCvv.textContent = value.length > 0 ? value : '***';
        });

        // Form gönderimi (backend entegrasyonu için hazır)
        document.getElementById('paymentForm').addEventListener('submit', function (e) {
            e.preventDefault();
            // TODO: PaymentController'a POST isteği burada tetiklenecek
            console.log('Ödeme bilgileri gönderiliyor...');
        });
    })();
</script>