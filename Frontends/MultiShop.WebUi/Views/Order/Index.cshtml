@model CreateOrderAddressDto
@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/UiLayout/Index.cshtml";
}

<div class="container-fluid">
    <div class="row px-xl-5">
        <div class="col-lg-8">
            <h5 class="section-title position-relative text-uppercase mb-3"><span class="bg-secondary pr-3">Adres</span></h5>
            <div class="bg-light p-30 mb-5">
                <form method="post">
                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label>Ad</label>
                            <input class="form-control" asp-for="Name" type="text" placeholder="Ad">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Soyad</label>
                            <input class="form-control" asp-for="Surname" type="text" placeholder="Soyad">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>E-mail</label>
                            <input class="form-control" asp-for="Email" type="text" placeholder="email adresi">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Telefon Numarası</label>
                            <input class="form-control" asp-for="Phone" type="text" placeholder="Telefon Numarası">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Adres Satırı 1</label>
                            <input class="form-control" asp-for="Detail1" type="text" placeholder="Adres Satırı 1">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Adres Satırı 2</label>
                            <input class="form-control" asp-for="Detail2" type="text" placeholder="Adres Satırı 2">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Ülke</label>
                            <input class="form-control" asp-for="Country" type="text" placeholder="Ülke">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>Şehir</label>
                            <input class="form-control" asp-for="City" type="text" placeholder="Şehir">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>İlçe</label>
                            <input class="form-control" asp-for="District" type="text" placeholder="İlçe">
                        </div>
                        <div class="col-md-6 form-group">
                            <label>ZIP Code</label>
                            <input class="form-control" asp-for="ZipCode" type="text" placeholder="123">
                        </div>
                    </div>
                </form>
            </div>
        </div>
        <div class="col-lg-4">
            @await Component.InvokeAsync("_UiOrderSummaryComponent")

            @await Component.InvokeAsync("_UiOrderPaymentComponent")
        </div>
    </div>
</div>