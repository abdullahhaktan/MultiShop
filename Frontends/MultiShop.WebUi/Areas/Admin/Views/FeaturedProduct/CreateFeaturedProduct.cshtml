@model CreateFeaturedProductDto
@{
    ViewData["Title"] = "Öne Çıkan Ürün Ekle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

<section class="content pt-4">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card card-outline card-success shadow-lg">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold text-success">
                            <i class="fas fa-star mr-2"></i> Vitrine Yeni Ürün Ekle
                        </h3>
                    </div>
                    <form method="post">
                        <div class="card-body">
                            <div class="row">
                                <div class="form-group col-md-12">
                                    <label asp-for="ProductName" class="font-weight-bold">Ürün Adı</label>
                                    <input type="text" asp-for="ProductName" class="form-control" placeholder="Örn: Akıllı Telefon X" required />
                                    <span asp-validation-for="ProductName" class="text-danger small"></span>
                                </div>

                                <div class="form-group col-md-12">
                                    <label asp-for="ImageUrl" class="font-weight-bold">Ürün Görsel Linki (URL)</label>
                                    <input type="text" asp-for="ImageUrl" class="form-control" placeholder="https://.../resim.jpg" required />
                                    <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                                </div>

                                <div class="form-group col-md-6">
                                    <label asp-for="Price" class="font-weight-bold">Satış Fiyatı (₺)</label>
                                    <input type="number" step="0.01" asp-for="Price" class="form-control" placeholder="0.00" required />
                                    <span asp-validation-for="Price" class="text-danger small"></span>
                                </div>

                                <div class="form-group col-md-6">
                                    <label asp-for="OldPrice" class="font-weight-bold">İndirim Öncesi Fiyatı (Opsiyonel)</label>
                                    <input type="number" step="0.01" asp-for="OldPrice" class="form-control" placeholder="0.00" />
                                </div>

                                <div class="form-group col-md-6">
                                    <label asp-for="Rating" class="font-weight-bold">Başlangıç Puanı (0 - 5 Arası)</label>
                                    <input type="number" step="0.1" min="0" max="5" asp-for="Rating" class="form-control" placeholder="4.5" required />
                                </div>

                                <div class="form-group col-md-6">
                                    <label asp-for="ReviewCount" class="font-weight-bold">Yorum/Değerlendirme Sayısı</label>
                                    <input type="number" asp-for="ReviewCount" class="form-control" placeholder="0" required />
                                </div>
                            </div>
                        </div>

                        <div class="card-footer bg-white d-flex justify-content-between border-top">
                            <a href="/Admin/FeaturedProduct/Index" class="btn btn-default border">
                                <i class="fas fa-chevron-left mr-1"></i> Listeye Dön
                            </a>
                            <button type="submit" class="btn btn-success px-4 font-weight-bold">
                                <i class="fas fa-save mr-1"></i> Vitrin Ürününü Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>