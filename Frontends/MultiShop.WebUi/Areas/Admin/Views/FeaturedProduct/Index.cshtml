@model List<ResultFeaturedProductDto>
@{
    ViewData["Title"] = "Öne Çıkan Ürünler";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

<section class="content pt-3">
    <div class="container-fluid">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-header border-0 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="card-title font-weight-bold mb-0">
                        <i class="fa-solid fa-star mr-2 text-warning"></i> Öne Çıkan Ürünler Vitrini
                    </h3>
                    <a href="/Admin/FeaturedProduct/CreateFeaturedProduct" class="btn btn-primary btn-sm shadow-sm border-0">
                        <i class="fa-solid fa-plus-circle mr-1"></i> Yeni Vitrin Ürünü Ekle
                    </a>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-secondary">
                            <tr>
                                <th style="width: 70px" class="text-center border-top-0">#</th>
                                <th class="border-top-0">Ürün Bilgisi</th>
                                <th class="text-right border-top-0">Fiyat</th>
                                <th class="text-center border-top-0">Puan / Değerlendirme</th>
                                <th style="width: 250px" class="text-center border-top-0">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="text-center text-muted font-weight-bold">@count</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" alt="@item.ProductName" class="img-thumbnail mr-3" style="width:50px; height:50px; object-fit:cover; border-radius: 6px;" />
                                                }
                                                else
                                                {
                                                    <div class="mr-3 text-center bg-light text-muted" style="width:50px; height:50px; line-height:50px; border-radius: 6px; border: 1px solid #dee2e6;">
                                                        <i class="fa-solid fa-image"></i>
                                                    </div>
                                                }
                                                <span class="text-dark font-weight-bold">@item.ProductName</span>
                                            </div>
                                        </td>
                                        <td class="text-right align-middle">
                                            @if (item.OldPrice.HasValue && item.OldPrice > item.Price)
                                            {
                                                <del class="text-muted small mr-2">@item.OldPrice.Value.ToString("N2") ₺</del>
                                            }
                                            <strong class="text-success" style="font-size: 1.05rem;">@item.Price.ToString("N2") ₺</strong>
                                        </td>
                                        <td class="text-center align-middle">
                                            <div class="text-warning mb-1">
                                                <i class="fa-solid fa-star small"></i>
                                                <span class="text-dark font-weight-bold small">@item.Rating.ToString("F1")</span>
                                            </div>
                                            <span class="badge badge-light text-muted border">
                                                <i class="fa-solid fa-comments mr-1"></i> @item.ReviewCount Yorum
                                            </span>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group">
                                                <a href="/Admin/FeaturedProduct/UpdateFeaturedProduct/@item.Id" class="btn btn-info btn-sm shadow-sm mr-2 rounded">
                                                    <i class="fa-solid fa-pen-to-square mr-1"></i> Düzenle
                                                </a>
                                                <a href="/Admin/FeaturedProduct/DeleteFeaturedProduct/@item.Id"
                                                   class="btn btn-outline-danger btn-sm rounded shadow-sm"
                                                   onclick="return confirm('@item.ProductName vitrinden kaldırılacak. Emin misiniz?')">
                                                    <i class="fa-solid fa-trash-can mr-1"></i> Kaldır
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="mb-3">
                                            <i class="fa-solid fa-wand-magic-sparkles fa-3x text-muted opacity-25"></i>
                                        </div>
                                        <p class="text-muted italic">Ana sayfa vitrininde listelenen öne çıkan ürün bulunamadı.</p>
                                        <a href="/Admin/FeaturedProduct/CreateFeaturedProduct" class="btn btn-sm btn-primary">İlk Ürünü Öne Çıkar</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="card-footer bg-white text-muted small">
                Toplam <strong>@(Model?.Count ?? 0)</strong> adet ürün ana sayfa vitrininde sergileniyor.
            </div>
        </div>
    </div>
</section>

<style>
    .table td, .table th {
        vertical-align: middle !important;
    }
</style>