@model List<ResultBrandDto>

@{
    ViewData["Title"] = "Markalar";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<section class="content pt-4">
    <div class="container-fluid">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h4 class="mb-0 fw-bold" style="color:#1a1a2e;">
                    <i class="fa fa-tags mr-2" style="color:#6c63ff;"></i> Marka Yönetimi
                </h4>
                <p class="text-muted mb-0 mt-1">
                    Toplam <strong>@(Model?.Count ?? 0)</strong> marka listeleniyor.
                </p>
            </div>

            <a href="/Admin/Brand/CreateBrand" class="btn btn-add-brand">
                <i class="fa fa-plus mr-1"></i> Yeni Marka
            </a>
        </div>

        <br />

        <div class="row">

            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    count++;
                    <div class="col-xl-3 col-lg-4 col-md-6 mb-4">
                        <div class="brand-card">

                            <div class="brand-image-area">

                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" class="brand-image" />
                                }
                                else
                                {
                                    <div class="no-image">
                                        <i class="fa fa-image fa-3x"></i>
                                        <span>Logo Yok</span>
                                    </div>
                                }

                            </div>

                            <div class="brand-footer">

                                <span class="brand-id">
                                    #@count
                                </span>

                                <div class="brand-actions">
                                    <a href="/Admin/Brand/UpdateBrand/@item.Id"
                                       class="action-btn btn-edit">
                                        <i class="fa fa-pencil"></i>
                                    </a>

                                    <a href="/Admin/Brand/DeleteBrand/@item.Id"
                                       class="action-btn btn-delete"
                                       onclick="return confirm('Markayı silmek istediğinize emin misiniz?')">
                                        <i class="fa fa-trash"></i>
                                    </a>
                                </div>

                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <i class="fa fa-inbox fa-3x mb-3"></i>
                        <h5>Henüz marka bulunmuyor</h5>
                        <p class="text-muted">
                            Sisteme ilk markayı ekleyebilirsiniz.
                        </p>
                    </div>
                </div>
            }

        </div>

    </div>
</section>

<style>

    .btn-add-brand {
        background: linear-gradient(135deg,#6c63ff,#4f46e5);
        color: white;
        border-radius: 10px;
        padding: 10px 22px;
        font-weight: 600;
        border: none;
    }

    .brand-card {
        background: white;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #eee;
        transition: .3s;
        margin-bottom: 20px;
    }

        .brand-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,.08);
        }

    .brand-image-area {
        height: 220px;
        display: flex;
        justify-content: center;
        align-items: center;
        background: #fafafa;
        padding: 25px;
    }

    .brand-image {
        max-width: 100%;
        max-height: 140px;
        object-fit: contain;
    }

    .brand-footer {
        padding: 15px;
        border-top: 1px solid #f2f2f2;
        display: flex;
        justify-content: space-between;
        align-items: center;
    }

    .brand-id {
        font-weight: 700;
        color: #6c63ff;
    }

    .brand-actions {
        display: flex;
        gap: 8px;
    }

    .action-btn {
        width: 38px;
        height: 38px;
        display: flex;
        justify-content: center;
        align-items: center;
        border-radius: 8px;
        text-decoration: none;
    }

    .btn-edit {
        background: #e8f4ff;
        color: #1890ff;
    }

    .btn-delete {
        background: #fff0f0;
        color: #e05252;
    }

    .no-image {
        display: flex;
        flex-direction: column;
        gap: 10px;
        color: #bbb;
        align-items: center;
    }

    .empty-state {
        text-align: center;
        padding: 60px;
        background: white;
        border-radius: 16px;
    }

</style>