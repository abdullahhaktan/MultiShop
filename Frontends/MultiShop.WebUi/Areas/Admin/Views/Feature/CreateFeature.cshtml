@model CreateFeatureDto
@{
    ViewData["Title"] = "Yeni Özellik";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content pt-3">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-8">
                <div class="card card-outline card-success shadow-lg">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">
                            <i class="fa fa-plus-circle mr-2 text-success"></i> Yeni Özellik Tanımla
                        </h3>
                    </div>
                    <form method="post">
                        <div class="card-body">
                            <div class="form-group">
                                <label class="font-weight-bold">Özellik Başlığı</label>
                                <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Ücretsiz Kargo, 7/24 Destek vb." />
                                <span asp-validation-for="Title" class="text-danger small"></span>
                            </div>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <a href="/Admin/Feature/Index" class="text-muted">
                                <i class="fa fa-arrow-left mr-1"></i> Vazgeç
                            </a>
                            <button type="submit" class="btn btn-success px-5 shadow-sm">
                                <i class="fa fa-save mr-2"></i> Özelliği Oluştur
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>