@model GetFeatureSliderByIdDto
@{
    ViewData["Title"] = "Slider Güncelle";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content pt-3">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-10">
                <div class="card card-outline card-warning shadow-lg">
                    <div class="card-header bg-white">
                        <h3 class="card-title font-weight-bold text-warning">
                            <i class="fa fa-refresh mr-2"></i> Slider Bilgilerini Güncelle
                        </h3>
                    </div>
                    <form method="post">
                        <div class="card-body">
                            <input type="hidden" asp-for="Id" />
                            <div class="row">
                                <div class="col-md-8">
                                    <div class="form-group">
                                        <label class="font-weight-bold text-muted small uppercase">Slider Başlığı</label>
                                        <input type="text" asp-for="Title" class="form-control border-left-warning shadow-sm" />
                                        <span asp-validation-for="Title" class="text-danger small"></span>
                                    </div>
                                    <div class="form-group">
                                        <label class="font-weight-bold text-muted small uppercase">Slider Açıklaması</label>
                                        <textarea asp-for="Description" class="form-control" rows="6"></textarea>
                                        <span asp-validation-for="Description" class="text-danger small"></span>
                                    </div>
                                </div>
                                <div class="col-md-4 d-flex flex-column justify-content-between">
                                    <div class="form-group p-3 bg-light border rounded">
                                        <label class="small font-weight-bold d-block text-muted">Mevcut / Yeni Görsel Linki</label>
                                        <input type="text" asp-for="ImageUrl" class="form-control form-control-sm mb-3" />
                                        <span asp-validation-for="ImageUrl" class="text-danger small"></span>

                                        @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                                        {
                                            <label class="small font-weight-bold d-block text-muted">Görsel Önizleme</label>
                                            <img src="@Model.ImageUrl" class="img-fluid rounded border shadow-sm" style="max-height: 120px; object-fit: cover; width: 100%;" />
                                        }
                                    </div>

                                    <div class="form-group p-3 bg-light border rounded">
                                        <label class="font-weight-bold small d-block text-muted mb-2">Görünürlük Durumu</label>
                                        <div class="custom-control custom-switch">
                                            <input type="checkbox" asp-for="Status" class="custom-control-input" id="StatusSwitch">
                                            <label class="custom-control-label" for="StatusSwitch">Slider Aktif</label>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer bg-white d-flex justify-content-between">
                            <a href="/Admin/FeatureSlider/Index" class="btn btn-light border">
                                <i class="fa fa-times-circle mr-1"></i> Değişiklikleri İptal Et
                            </a>
                            <button type="submit" class="btn btn-warning px-4 font-weight-bold">
                                <i class="fa fa-check mr-2"></i> Değişiklikleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>