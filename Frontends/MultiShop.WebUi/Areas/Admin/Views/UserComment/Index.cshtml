@model List<ResultUserCommentDto>

@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<div class="container-fluid pt-4 px-4">
    <div class="bg-light text-center rounded p-4">
        <div class="d-flex align-items-center justify-content-between mb-4">
            <h5 class="mb-0 text-dark font-weight-bold" style="display: flex; align-items: center; justify-content: space-between; width: 100%;">
                <span><i class="fa fa-comments text-primary me-2"></i> Kullanıcı Yorumları Yönetimi</span>
                <span class="badge bg-primary rounded-pill py-2 px-3" style="font-size: 14px; background-color: #007bff; color:white;">Toplam: @(Model?.Count ?? 0) Yorum</span>
            </h5>
        </div>

        <div class="table-responsive">
            <table class="table text-start align-middle table-bordered table-hover mb-0">
                <thead>
                    <tr class="text-dark table-secondary" style="background-color: #f8f9fa;">
                        <th scope="col" style="width: 5%">#</th>
                        <th scope="col" style="width: 15%">Kullanıcı</th>
                        <th scope="col" style="width: 15%">E-Posta</th>
                        <th scope="col" style="width: 30%">Yorum Detayı</th>
                        <th scope="col" style="width: 12%">Puan (Rating)</th>
                        <th scope="col" style="width: 10%">Tarih</th>
                        <th scope="col" style="width: 5%">Durum</th>
                        <th scope="col" style="width: 8%; text-align: center;">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td><strong>@item.Id</strong></td>
                                <td>
                                    <div class="d-flex align-items-center" style="display: flex; align-items: center;">
                                        <img class="rounded-circle me-2" src="@(string.IsNullOrEmpty(item.ImageUrl) ? "/images/default-avatar.png" : item.ImageUrl)" alt="" style="width: 35px; height: 35px; object-fit: cover; border-radius: 50%; margin-right: 8px;">
                                        <span class="fw-bold text-secondary">@item.NameSurname</span>
                                    </div>
                                </td>
                                <td><small class="text-muted">@item.Email</small></td>
                                <td>
                                    <span class="text-truncate d-inline-block" style="max-width: 280px; display: inline-block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title="@item.CommentDetail">
                                        @item.CommentDetail
                                    </span>
                                </td>
                                <td>
                                    <div class="text-warning" style="color: #ffc107;">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            if (i <= item.Rating)
                                            {
                                                <i class="fa fa-star"></i>
                                            }
                                            else
                                            {
                                                <i class="fa fa-star-o"></i>
                                            }
                                        }
                                    </div>
                                </td>
                                <td><small>@item.CreatedDate.ToString("dd.MM.yyyy")</small></td>
                                <td>
                                    @if (item.Status)
                                    {
                                        <span class="badge bg-success px-2 py-1" style="background-color: #28a745; color: white; padding: 3px 8px; border-radius: 4px;">Aktif</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger px-2 py-1" style="background-color: #dc3545; color: white; padding: 3px 8px; border-radius: 4px;">Pasif</span>
                                    }
                                </td>
                                <td class="text-center" style="text-align: center;">
                                    <div class="btn-group" role="group" style="display: inline-flex;">
                                        <a href="/Admin/UserComment/UpdateUserComment/@item.Id" class="btn btn-sm btn-warning" title="Güncelle" style="padding: 2px 8px; margin-right: 3px; background-color: #ffc107; border: none; color: #000;">
                                            <i class="fa fa-pencil"></i>
                                        </a>
                                        <a href="/Admin/UserComment/DeleteUserComment/@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('Bu yorumu silmek istediğinize emin misiniz?')" title="Sil" style="padding: 2px 8px; background-color: #dc3545; border: none; color: white;">
                                            <i class="fa fa-trash"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="8" class="text-center text-muted py-4" style="text-align: center; color: #6c757d; padding: 20px;">
                                <i class="fa fa-info-circle me-2"></i> Listelenecek herhangi bir kullanıcı yorumu bulunamadı.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: #f8f9fa;
        transition: background-color 0.2s ease;
    }
</style>