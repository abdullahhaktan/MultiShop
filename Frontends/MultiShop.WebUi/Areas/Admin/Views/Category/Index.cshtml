@model List<ResultCategoryDto>
@{
    ViewData["Title"] = "Kategoriler";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
    int count = 0;
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

<section class="content pt-3">
    <div class="container-fluid">
        <div class="card card-outline card-primary shadow-sm">
            <div class="card-header border-0 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <h3 class="card-title font-weight-bold mb-0">
                        <i class="fa-solid fa-layer-group mr-2 text-primary"></i> Kategori Yönetimi
                    </h3>
                    <a href="/Admin/Category/CreateCategory" class="btn btn-primary btn-sm shadow-sm border-0">
                        <i class="fa-solid fa-plus-circle mr-1"></i> Yeni Kategori Ekle
                    </a>
                </div>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light text-secondary">
                            <tr>
                                <th style="width: 80px" class="text-center border-top-0">#</th>
                                <th class="border-top-0">Kategori Bilgisi</th>
                                <th class="text-center border-top-0">Bağlı Ürün Sayısı</th>
                                <th class="text-center border-top-0">Aksiyon</th>
                                <th style="width: 280px" class="text-center border-top-0">İşlemler</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    count++;
                                    <tr>
                                        <td class="text-center text-muted font-weight-bold">@count</td>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                {
                                                    <img src="@item.ImageUrl" alt="@item.Name" class="img-thumbnail mr-3" style="width:45px; height:45px; object-fit:cover; border-radius: 8px;" />
                                                }
                                                else
                                                {
                                                    <div class="mr-3 text-center bg-light text-muted" style="width:45px; height:45px; line-height:45px; border-radius: 8px; border: 1px solid #dee2e6;">
                                                        <i class="fa-solid fa-image"></i>
                                                    </div>
                                                }
                                                <span class="text-dark font-weight-bold" style="font-size: 1.05rem;">@item.Name</span>
                                            </div>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge badge-secondary px-3 py-2 font-weight-bold" style="font-size: 0.9rem; border-radius: 6px;">
                                                <i class="fa-solid fa-box mr-1"></i> @(item.CategoryProductCount ?? 0) Ürün
                                            </span>
                                        </td>
                                        <td class="text-center align-middle">
                                            <a href="#" class="btn btn-outline-info rounded-pill px-3 shadow-sm" title="Ürünleri Gör" style="transition: all 0.3s;">
                                                <i class="fa-solid fa-eye fa-lg mr-1"></i>
                                                <span class="font-weight-bold" style="font-size: 0.85rem;">Ürünler</span>
                                            </a>
                                        </td>
                                        <td class="text-center">
                                            <div class="btn-group">
                                                <a href="/Admin/Category/UpdateCategory/@item.Id" class="btn btn-info btn-sm shadow-sm mr-2 rounded">
                                                    <i class="fa-solid fa-pen-to-square mr-1"></i> Düzenle
                                                </a>
                                                <a href="/Admin/Category/DeleteCategory/@item.Id"
                                                   class="btn btn-outline-danger btn-sm rounded shadow-sm"
                                                   onclick="return confirm('@item.Name kategorisini silmek istediğinize emin misiniz?')">
                                                    <i class="fa-solid fa-trash-can mr-1"></i> Sil
                                                </a>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center py-5">
                                        <div class="mb-3">
                                            <i class="fa-solid fa-inbox fa-3x text-muted opacity-25"></i>
                                        </div>
                                        <p class="text-muted italic">Kayıtlı kategori bulunamadı.</p>
                                        <a href="/Admin/Category/CreateCategory" class="btn btn-sm btn-primary">Hemen Bir Tane Ekle</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="card-footer bg-white border-top-0 text-right">
                <span class="badge badge-light p-2 text-muted">
                    <i class="fa-solid fa-database mr-1"></i> Toplam: @(Model?.Count ?? 0) Kategori
                </span>
            </div>
        </div>
    </div>
</section>

<style>
    .table td, .table th {
        vertical-align: middle !important;
    }

    .shadow-sm {
        box-shadow: 0 .125rem .25rem rgba(0,0,0,.075) !important;
    }
</style>