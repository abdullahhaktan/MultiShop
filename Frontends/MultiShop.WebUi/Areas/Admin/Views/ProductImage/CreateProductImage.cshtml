@model MultiShop.DtoLayer.ProductImageDtos.CreateProductImageDto
@{
    ViewData["Title"] = "Yeni Ürün Görseli";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content pt-3">
    <div class="container-fluid">
        <div class="row justify-content-center">
            <div class="col-md-9">
                <div class="card card-outline card-success shadow-lg">
                    <div class="card-header">
                        <h3 class="card-title font-weight-bold">
                            <i class="fa fa-picture-o mr-2 text-success"></i> Ürün Görsel Seti Tanımlama
                        </h3>
                    </div>
                    <form method="post">
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-12 mb-3">
                                    <div class="form-group bg-light p-3 rounded border">
                                        <label class="font-weight-bold text-primary">Görsellerin Bağlanacağı Ürün</label>
                                        <select asp-for="ProductId" class="form-control custom-select">
                                            <option value="">-- Görsel Eklenecek Ürünü Seçiniz --</option>
                                            @if (ViewBag.Products != null)
                                            {
                                                @foreach (var prod in ViewBag.Products)
                                                {
                                                    <option value="@prod.Id">@prod.ProductName</option>
                                                }
                                            }
                                        </select>
                                        <span asp-validation-for="ProductId" class="text-danger small"></span>
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="font-weight-bold">1. Görsel URL</label>
                                        <input type="text" asp-for="Image1" class="form-control" placeholder="https://..." />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="font-weight-bold">2. Görsel URL</label>
                                        <input type="text" asp-for="Image2" class="form-control" placeholder="https://..." />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="font-weight-bold">3. Görsel URL</label>
                                        <input type="text" asp-for="Image3" class="form-control" placeholder="https://..." />
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="form-group">
                                        <label class="font-weight-bold">4. Görsel URL</label>
                                        <input type="text" asp-for="Image4" class="form-control" placeholder="https://..." />
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-footer d-flex justify-content-between align-items-center">
                            <a href="/Admin/ProductImage/Index" class="text-muted">
                                <i class="fa fa-arrow-left mr-1"></i> İptal Et ve Dön
                            </a>
                            <button type="submit" class="btn btn-success px-5 shadow-sm">
                                <i class="fa fa-save mr-2"></i> Görselleri Kaydet
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>