@model List<ResultProductImageWithProductDto>
@{
    ViewData["Title"] = "Ürün Görselleri";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content pt-4">
    <div class="container-fluid">

        <div class="d-flex justify-content-between align-items-center mb-4 px-1">
            <div>
                <h4 class="mb-0 fw-bold" style="color:#1a1a2e;">
                    <i class="fa fa-picture-o mr-2" style="color:#6c63ff;"></i> Ürün Görsel Galerisi
                </h4>
                <p class="text-muted mb-0 small mt-1">Toplam <strong>@(Model?.Count ?? 0)</strong> ürünün görsel seti listeleniyor.</p>
            </div>
            <a href="/Admin/ProductImage/CreateProductImage" class="btn btn-add-image">
                <i class="fa fa-plus mr-1"></i> Yeni Görsel Seti Ekle
            </a>
        </div>

        <br />

        <div class="row">
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <div class="col-xl-4 col-lg-6 col-md-6 mb-4">
                        <div class="gallery-card">

                            <div class="gallery-header">
                                <span class="product-badge">
                                    <i class="fa fa-cube mr-1"></i>@(item.Product?.ProductName ?? "Bilinmeyen Ürün")
                                </span>
                            </div>

                            <div class="gallery-thumbs-row">
                                <div class="thumb-box">
                                    @if (!string.IsNullOrEmpty(item.Image1))
                                    {
                                        <img src="@item.Image1" alt="Görsel 1" class="img-fluid gallery-thumb" />
                                        <span class="img-idx">1</span>
                                    }
                                    else
                                    {
                                        <div class="no-thumb"><i class="fa fa-image mb-1"></i><span>Boş</span></div>
                                    }
                                </div>
                                <div class="thumb-box">
                                    @if (!string.IsNullOrEmpty(item.Image2))
                                    {
                                        <img src="@item.Image2" alt="Görsel 2" class="img-fluid gallery-thumb" />
                                        <span class="img-idx">2</span>
                                    }
                                    else
                                    {
                                        <div class="no-thumb"><i class="fa fa-image mb-1"></i><span>Boş</span></div>
                                    }
                                </div>
                                <div class="thumb-box">
                                    @if (!string.IsNullOrEmpty(item.Image3))
                                    {
                                        <img src="@item.Image3" alt="Görsel 3" class="img-fluid gallery-thumb" />
                                        <span class="img-idx">3</span>
                                    }
                                    else
                                    {
                                        <div class="no-thumb"><i class="fa fa-image mb-1"></i><span>Boş</span></div>
                                    }
                                </div>
                                <div class="thumb-box">
                                    @if (!string.IsNullOrEmpty(item.Image4))
                                    {
                                        <img src="@item.Image4" alt="Görsel 4" class="img-fluid gallery-thumb" />
                                        <span class="img-idx">4</span>
                                    }
                                    else
                                    {
                                        <div class="no-thumb"><i class="fa fa-image mb-1"></i><span>Boş</span></div>
                                    }
                                </div>
                            </div>

                            <div class="gallery-body">
                                <div class="gallery-actions">
                                    <a href="/Admin/ProductImage/UpdateProductImage/@item.Id" class="action-btn btn-edit" title="Düzenle">
                                        <i class="fa fa-pencil mr-1"></i> Düzenle
                                    </a>
                                    <a href="/Admin/ProductImage/DeleteProductImage/@item.Id"
                                       class="action-btn btn-delete" title="Sil"
                                       onclick="return confirm('@(item.Product?.ProductName) görsel setini silmek istediğinize emin misiniz?')">
                                        <i class="fa fa-trash mr-1"></i> Sil
                                    </a>
                                </div>
                            </div>

                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12">
                    <div class="empty-state">
                        <i class="fa fa-images fa-3x mb-3"></i>
                        <h5>Henüz görsel seti tanımlanmamış</h5>
                        <p class="text-muted">Ürünlerinize galeri görselleri eklemek için "Yeni Görsel Seti Ekle" butonunu kullanın.</p>
                    </div>
                </div>
            }
        </div>

    </div>
</section>

<style>
    .btn-add-image {
        background: linear-gradient(135deg, #6c63ff, #4f46e5);
        color: #fff;
        border: none;
        border-radius: 10px;
        padding: 9px 22px;
        font-weight: 600;
        font-size: 0.875rem;
        transition: all 0.25s;
        box-shadow: 0 4px 14px rgba(108,99,255,0.35);
    }

        .btn-add-image:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(108,99,255,0.45);
        }

    .gallery-card {
        background: #fff;
        border-radius: 16px;
        overflow: hidden;
        border: 1px solid #f0f0f5;
        transition: all 0.3s ease;
        display: flex;
        flex-direction: column;
    }

        .gallery-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.08);
            border-color: #e0deff;
        }

    .gallery-header {
        padding: 14px 16px;
        background: #fafafc;
        border-bottom: 1px solid #f0f0f5;
    }

    .product-badge {
        font-size: 0.88rem;
        font-weight: 700;
        color: #1a1a2e;
        display: block;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .gallery-thumbs-row {
        display: flex;
        gap: 10px;
        padding: 16px;
        background: #fdfdfd;
    }

    .thumb-box {
        flex: 1;
        position: relative;
        height: 100px;
        background: #f7f7fb;
        border: 1px solid #eaeaea;
        border-radius: 8px;
        overflow: hidden;
    }

    .gallery-thumb {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .img-idx {
        position: absolute;
        bottom: 4px;
        right: 4px;
        background: rgba(0,0,0,0.6);
        color: #fff;
        font-size: 10px;
        padding: 1px 5px;
        border-radius: 4px;
    }

    .no-thumb {
        height: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #ccc;
        font-size: 11px;
    }

    .gallery-body {
        padding: 0 16px 16px 16px;
        margin-top: auto;
    }

    .gallery-actions {
        display: flex;
        gap: 10px;
        border-top: 1px solid #f2f2f7;
        padding-top: 12px;
    }

    .action-btn {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        height: 34px;
        border-radius: 8px;
        font-size: 0.82rem;
        font-weight: 600;
        border: none;
        transition: all 0.2s;
        text-decoration: none;
    }

    .btn-edit {
        background: #e6f7ff;
        color: #1890ff;
    }

        .btn-edit:hover {
            background: #1890ff;
            color: #fff;
        }

    .btn-delete {
        background: #fff0f0;
        color: #e05252;
    }

        .btn-delete:hover {
            background: #e05252;
            color: #fff;
        }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        background: #fff;
        border-radius: 16px;
        border: 1px solid #f0f0f5;
        color: #aaa;
    }

        .empty-state h5 {
            color: #555;
            font-weight: 700;
            margin-bottom: 8px;
        }
</style>