@model List<ResultOrderingByUserIdDto>
@{
    ViewData["Title"] = "Siparişlerim";
    Layout = "~/Areas/User/Views/UserLayout/Index.cshtml";
    int count = 0;
    string tableRowColor = "";
}

<div class="row">
    <div class="col-lg-12 grid-margin stretch-card">
        <div class="card">
            <div class="card-body">
                <h4 class="card-title">Siparişlerim</h4>
                <p class="card-description">
                    Tüm sipariş geçmişiniz <code>burada listelenmektedir</code>
                </p>
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Sipariş No</th>
                                <th>Sipariş Tarihi</th>
                                <th>Toplam Tutar</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    count++;

                                    if (count == 1) { tableRowColor = "table-info"; }
                                    if (count == 2) { tableRowColor = "table-warning"; }
                                    if (count == 3) { tableRowColor = "table-danger"; }
                                    if (count == 4) { tableRowColor = "table-success"; }
                                    if (count == 5) { tableRowColor = "table-primary"; }
                                    if (count == 6) { tableRowColor = "table-dark"; }
                                    if (count == 7) { tableRowColor = "table-secondary"; }

                                    <tr class="@tableRowColor">
                                        <td>#@count</td>
                                        <td>@item.OrderDate.ToString("dd MMMM yyyy")</td>
                                        <td>@item.TotalPrice.ToString("C2")</td>
                                        <td>
                                            <label class="badge badge-success">Tamamlandı</label>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center">
                                        <div class="my-4">
                                            <i class="mdi mdi-cart-off" style="font-size: 48px; color: #6c757d;"></i>
                                            <p class="mt-2">Henüz hiç siparişiniz bulunmamaktadır.</p>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .table-hover tbody tr:hover {
        background-color: rgba(13, 110, 253, 0.05);
        transition: all 0.3s ease;
    }

    .badge-success {
        background: linear-gradient(45deg, #2ecc71, #27ae60) !important;
    }

    .card {
        box-shadow: 0 4px 6px rgba(0,0,0,0.07);
        border: none;
    }

    .table th {
        border-top: none;
        font-weight: 600;
        color: #495057;
    }

    .table td {
        vertical-align: middle;
    }
</style>